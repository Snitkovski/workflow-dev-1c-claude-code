# Параметры проекта 1С для Claude Code
# Скопируйте в .dev.env и заполните значениями проекта
#
# Prefix for all new metadata objects, attributes, form elements, roles
# Префикс для ВСЕХ новых объектов метаданных, реквизитов, элементов форм, ролей
# Example / Пример: гр, лтх, бэкс, бтех
PREFIX=

# Company/project name for modification comments
# Имя компании/проекта для комментариев модификации
COMPANY=

# Developer name for modification comments
# Имя разработчика для комментариев модификации
DEVELOPER=

# Minimum required 1C:Enterprise platform version
# Минимальная требуемая версия платформы 1С:Предприятие
# Determines available features (e.g. Async/Await from 8.3.18)
PLATFORM_VERSION=8.3.25

# Modification comment templates (for typical code changes)
# Шаблоны комментариев модификации (для изменений типового кода)
# Placeholders: {COMPANY}, {DEVELOPER}, {DATE}, {TASK}
COMMENT_OPEN=// +++ {COMPANY}; {DEVELOPER}; {DATE}; {TASK}
COMMENT_CLOSE=// --- {COMPANY}; {DEVELOPER}; {DATE}; {TASK}

# Where to place new metadata objects: main_configuration | extension
# Где создавать новые объекты: main_configuration | extension
NEW_OBJECTS_IN=main_configuration
